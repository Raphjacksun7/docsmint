{
  "name": "mkdocx",
  "type": "module",
  "version": "0.1.0",
  "description": "Minimal markdown documentation builder with a transfa-inspired aesthetic.",
  "keywords": [
    "docs",
    "documentation",
    "markdown",
    "astro",
    "static-site"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "mkdocx": "./bin/mkdocx.js"
  },
  "files": [
    "src",
    "bin",
    "public",
    "astro.config.mjs",
    "mkdocx.config.js",
    "tailwind.config.mjs",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "mermaid": "^11.14.0",
    "pagefind": "^1.5.0",
    "rehype-external-links": "^3.0.0",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "unist-util-visit": "^5.1.0"
  }
}
