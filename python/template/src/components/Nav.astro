---
import Search from './Search.astro'
import ThemeToggle from './ThemeToggle.astro'
import { getCollection } from 'astro:content'

export interface Props {
  site: { name: string; nav?: { label: string; href: string }[] }
}
const { site } = Astro.props

// Resolve /docs to the actual first doc page so there's no redirect blink
let firstDocHref = '/docs'
try {
  const docs = (await getCollection('docs'))
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  if (docs[0]) firstDocHref = `/docs/${docs[0].id.replace(/\.mdx?$/, '')}`
} catch {}

const nav = (site.nav || []).map(item =>
  item.href === '/docs' ? { ...item, href: firstDocHref } : item
)
---
<header class="max-w-3xl mx-auto px-8 py-5">
  <div class="flex items-center justify-between gap-4">
    <a href="/"
       data-no-hover
       class="text-sm font-bold"
       style="text-decoration:none">
      {site.name}
    </a>
    <div class="flex items-center gap-5">
      {nav.map(({ label, href }) => (
        <a href={href} class="text-sm text-zinc-500 hidden sm:inline">{label}</a>
      ))}
      <Search />
      <ThemeToggle />
    </div>
  </div>
  {nav.length > 0 && (
    <nav class="flex items-center gap-5 mt-2 sm:hidden">
      {nav.map(({ label, href }) => (
        <a href={href} class="text-sm text-zinc-500">{label}</a>
      ))}
    </nav>
  )}
</header>
