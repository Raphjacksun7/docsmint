---
import Search from './Search.astro'
import ThemeToggle from './ThemeToggle.astro'
export interface Props {
  site: { name: string; nav?: { label: string; href: string }[] }
}
const { site } = Astro.props
const nav = site.nav || []
---
<header class="max-w-3xl mx-auto px-8 py-5">
  <!-- Top row: logo + controls always visible -->
  <div class="flex items-center justify-between gap-4">
    <a href="/"
       data-no-hover
       class="text-sm font-bold"
       style="text-decoration:none">
      {site.name}
    </a>
    <div class="flex items-center gap-5">
      {nav.map(({ label, href }) => (
        <a href={href} class="text-sm text-zinc-500 hidden sm:inline">{label}</a>
      ))}
      <Search />
      <ThemeToggle />
    </div>
  </div>
  <!-- Below-logo nav for narrow screens -->
  {nav.length > 0 && (
    <nav class="flex items-center gap-5 mt-2 sm:hidden">
      {nav.map(({ label, href }) => (
        <a href={href} class="text-sm text-zinc-500">{label}</a>
      ))}
    </nav>
  )}
</header>
