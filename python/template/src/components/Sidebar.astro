---
import { getCollection } from 'astro:content'

const docs = await getCollection('docs')

const tree: Record<string, { title: string; href: string; order: number }[]> = {}

for (const entry of docs) {
  const parts = entry.id.replace(/\.mdx?$/, '').split('/')
  const section = parts.length > 1 ? parts[0] : ''
  tree[section] = tree[section] || []
  tree[section].push({
    title: entry.data.title,
    href: `/docs/${entry.id.replace(/\.mdx?$/, '')}`,
    order: entry.data.order ?? 99,
  })
}

const sections = Object.entries(tree).sort(([a], [b]) => a.localeCompare(b))
for (const [, pages] of sections) pages.sort((a, b) => a.order - b.order)
const currentPath = Astro.url.pathname.replace(/\/$/, '')
---
<nav class="text-sm space-y-6">
  {sections.map(([section, pages]) => (
    <div>
      {section && (
        <p class="font-bold text-xs uppercase tracking-wide mb-2">{section}</p>
      )}
      <ul class="space-y-1">
        {pages.map(({ title, href }) => (
          <li>
            <a
              href={href}
              class:list={['sidebar-link block py-0.5 transition-all text-sm', currentPath === href ? 'font-bold sidebar-active' : 'text-zinc-500']}
              style={currentPath === href ? 'text-decoration:none; font-size:0.9188rem' : ''}
            >{title}</a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>
